# Required for local development
# Use a direct PostgreSQL connection for migrations. Replace this example password.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voxmint
# Generate a value with: npx auth secret
AUTH_SECRET=replace-with-a-random-development-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Safe local-development defaults
VOICE_PROVIDER=mock
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=.data/storage
RATE_LIMIT_PROVIDER=memory
DEV_BYPASS_AUTH=true
E2E_TEST_AUTH=false

# Optional Google OAuth. Configure both values together.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Optional email magic-link login. Configure both values together.
# AUTH_EMAIL_SERVER=
# AUTH_EMAIL_FROM=

# Optional Cartesia voice provider. Required only when VOICE_PROVIDER=cartesia.
# CARTESIA_API_KEY=
CARTESIA_API_VERSION=2026-03-01
CARTESIA_TTS_MODEL=sonic-3

# Optional Cloudflare R2/S3-compatible storage. Required only when STORAGE_PROVIDER=r2.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=

# Optional Upstash rate limiting. Required only when RATE_LIMIT_PROVIDER=upstash.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Upload and generation limits
VOICE_SAMPLE_MIN_SECONDS=3
VOICE_SAMPLE_MAX_SECONDS=10
VOICE_SAMPLE_MAX_BYTES=10485760
GENERATION_MAX_CHARACTERS=5000

# Cost controls. These are deployment ceilings, not a live provider balance.
VOICE_CREATIONS_PER_HOUR=3
GENERATIONS_PER_MINUTE=20
DOWNLOADS_PER_MINUTE=120
DAILY_CHARACTER_LIMIT=25000
MONTHLY_CHARACTER_LIMIT=100000
GLOBAL_DAILY_CHARACTER_LIMIT=1000000
MAX_CONCURRENT_PROVIDER_REQUESTS=1
# false blocks new cloning/generation while existing audio remains available.
VOICE_OPERATIONS_ENABLED=true

# Launch posture and operator contacts. Never publish invented contacts.
PUBLIC_LAUNCH=false
# OPERATOR_NAME=
# SUPPORT_EMAIL=support@example.com
# SUPPORT_URL=https://example.com/support
# ABUSE_REPORT_EMAIL=abuse@example.com
# ABUSE_REPORT_URL=https://example.com/report-abuse
# PRIVACY_CONTACT_EMAIL=privacy@example.com
# POLICY_EFFECTIVE_DATE=2026-07-16
# LEGAL_JURISDICTION=France

# Optional background retention service
# Keep false unless a scheduled worker actually enforces the saved retention preference.
RETENTION_WORKER_ENABLED=false
SHOW_PROVIDER_BRANDING=true

# Application billing is intentionally disabled. There are no checkout or payment-provider
# variables until a BillingAdapter implementation and webhook flow are added.

# Production requirements:
# - Set DEV_BYPASS_AUTH=false and configure both Google OAuth values.
# - Set VOICE_PROVIDER=cartesia and configure CARTESIA_API_KEY.
# - Set STORAGE_PROVIDER=r2 and configure the required R2 values.
# - Set RATE_LIMIT_PROVIDER=upstash and configure both Upstash values.
# - Keep E2E_TEST_AUTH=false and never reuse TEST_DATABASE_URL.
# - Set PUBLIC_LAUNCH=true only after monitored contacts and policy metadata are configured.

# Test-job settings; never set these in production.
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voxmint_e2e
# LIVE_CARTESIA_E2E=false
# CARTESIA_E2E_API_KEY=
# CARTESIA_E2E_VOICE_ID=
