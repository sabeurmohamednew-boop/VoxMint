generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
}

enum ThemePreference {
  SYSTEM
  DARK
  LIGHT
}

enum VoiceStatus {
  PROCESSING
  READY
  FAILED
  DELETING
  DELETED
}

enum GenerationStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  DELETING
  DELETED
}

enum UsageType {
  TTS_CHARACTERS
  VOICE_CLONE
}

enum UsageStatus {
  RESERVED
  COMMITTED
  RELEASED
}

model User {
  id                   String          @id @default(cuid())
  name                 String?
  email                String?         @unique
  emailVerified        DateTime?
  image                String?
  role                 UserRole        @default(USER)
  plan                 Plan            @default(FREE)
  preferredLanguage    String          @default("en")
  preferredAudioFormat String          @default("wav")
  theme                ThemePreference @default(DARK)
  retentionDays        Int?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?
  accounts             Account[]
  sessions             Session[]
  voices               Voice[]
  generations          Generation[]
  consentRecords       ConsentRecord[]
  usageLedger          UsageLedger[]
  monthlyUsage         MonthlyUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Voice {
  id                 String          @id @default(cuid())
  userId             String
  provider           String
  providerVoiceId    String
  idempotencyKey     String?
  name               String
  description        String?
  primaryLanguage    String          @default("en")
  status             VoiceStatus     @default(PROCESSING)
  sourceMimeType     String
  sourceDurationMs   Int
  providerModel      String?
  providerMetadata   Json?
  consentConfirmedAt DateTime
  lastUsedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations        Generation[]
  consentRecords     ConsentRecord[]

  @@unique([provider, providerVoiceId])
  @@unique([userId, idempotencyKey])
  @@index([userId, status])
  @@index([userId, lastUsedAt])
}

model Generation {
  id                String           @id @default(cuid())
  userId            String
  voiceId           String
  retryOfId         String?
  idempotencyKey    String
  title             String?
  text              String
  textHash          String
  characterCount    Int
  language          String
  style             String?
  provider          String
  providerModel     String
  providerRequestId String?
  status            GenerationStatus @default(PENDING)
  storageKey        String?
  mimeType          String?
  fileSizeBytes     Int?
  durationMs        Int?
  errorCode         String?
  errorMessageSafe  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  completedAt       DateTime?
  deletedAt         DateTime?
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  voice             Voice            @relation(fields: [voiceId], references: [id], onDelete: Restrict)
  retryOf           Generation?      @relation("GenerationRetries", fields: [retryOfId], references: [id], onDelete: SetNull)
  retries           Generation[]     @relation("GenerationRetries")
  usageLedger       UsageLedger[]

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([voiceId, createdAt])
  @@index([status])
}

model ConsentRecord {
  id             String   @id @default(cuid())
  userId         String
  voiceId        String?
  consentVersion String
  statement      String
  confirmedAt    DateTime
  userAgentHash  String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voice          Voice?   @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  @@index([userId, confirmedAt])
}

model UsageLedger {
  id             String      @id @default(cuid())
  userId         String
  generationId   String?
  type           UsageType
  quantity       Int
  status         UsageStatus
  periodKey      String
  idempotencyKey String
  createdAt      DateTime    @default(now())
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation     Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@unique([userId, idempotencyKey])
  @@index([userId, periodKey, type, status])
}

model MonthlyUsage {
  userId         String
  periodKey      String
  charactersUsed Int      @default(0)
  voicesCreated  Int      @default(0)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, periodKey])
}
